APP_NAME=PulseGuest
ENV=dev
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:5173
PUBLIC_BASE_URL=https://apicultural-kaylee-superstrenuous.ngrok-free.dev

# Postgres
POSTGRES_DB=pulseguest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/pulseguest

# JWT
JWT_ISSUER=pulseguest
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
JWT_SECRET=change_me_in_prod_super_secret

# Optional: analytics privacy knobs later
STORE_IP=false

# Redis (one-time password reset tokens + rate-limit cooldown)
REDIS_URL=redis://redis:6379/0

# Admin frontend base URL (used in password reset email links)
FRONTEND_BASE_URL=http://localhost:5173

# SMTP (optional for now; will also be used later for notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_user
# SMTP_PASS=your_password
# SMTP_FROM=no-reply@example.com
# SMTP_TLS=true
# SMTP_SSL=false
