APP_NAME=PulseGuest
ENV=dev
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:5173

# Postgres
POSTGRES_DB=pulseguest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/pulseguest

# JWT
JWT_ISSUER=pulseguest
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600
JWT_SECRET=change_me_in_prod_super_secret

# Optional: analytics privacy knobs later
STORE_IP=false

